<?xml version="1.0" encoding="utf-8"?>
<mavlink>
  <include>common.xml</include>
  <version>3</version>
  <dialect>0</dialect>
  <enums>
    <!-- ===== 自定义指令枚举 ===== -->
    <enum name="HK_CMD">
      <description>蜂巢智控自定义 MAV_CMD（通过 COMMAND_LONG 下发）</description>
      <!-- 作战指令 51000~51002 -->
      <entry value="51000" name="HK_CMD_ASSIGN_TARGET">
        <description>装订目标</description>
      </entry>
      <entry value="51001" name="HK_CMD_TRACK_TARGET">
        <description>跟踪目标</description>
      </entry>
      <entry value="51002" name="HK_CMD_IMPACT_TARGET">
        <description>撞击目标</description>
      </entry>
      <!-- 载荷控制指令 52000~52004 -->
      <entry value="52000" name="HK_CMD_DO_MOUNT_CONTROL">
        <description>云台控制</description>
        <param index="1">pitch（°）</param>
        <param index="2">roll</param>
        <param index="3">yaw（°）</param>
      </entry>
      <entry value="52001" name="HK_CMD_IMAGE_START_CAPTURE">
        <description>拍照</description>
      </entry>
      <entry value="52002" name="HK_CMD_VIDEO_START_CAPTURE">
        <description>开始录像</description>
      </entry>
      <entry value="52003" name="HK_CMD_VIDEO_STOP_CAPTURE">
        <description>停止录像</description>
      </entry>
      <entry value="52004" name="HK_CMD_SET_CAMERA_MODE">
        <description>载荷切换</description>
        <param index="1">camera_id</param>
      </entry>
      <!-- 行为配置指令 53000 -->
      <entry value="53000" name="HK_CMD_SET_BEHAVIOR">
        <description>失联行为配置</description>
        <param index="1">行为类型（0=悬停, 1=返航）</param>
        <param index="2">触发时间（s）</param>
        <param index="3">功能开关（0=关, 1=开）</param>
      </entry>
      <!-- 发射箱指令 61000~61001 -->
      <entry value="61000" name="HK_CMD_LID_OPEN">
        <description>发射箱开盖</description>
        <param index="1">1=开 / 0=关</param>
      </entry>
      <entry value="61001" name="HK_CMD_LOCK_RELEASE">
        <description>发射箱电磁锁扣解锁</description>
        <param index="1">1=解锁 / 0=锁定</param>
      </entry>
    </enum>

    <!-- ===== GPS 定位类型 ===== -->
    <enum name="HK_GPS_FIX_TYPE">
      <description>GPS 定位类型</description>
      <entry value="0" name="HK_GPS_FIX_TYPE_NONE"><description>无</description></entry>
      <entry value="1" name="HK_GPS_FIX_TYPE_NONE2"><description>无</description></entry>
      <entry value="2" name="HK_GPS_FIX_TYPE_2D"><description>2D</description></entry>
      <entry value="3" name="HK_GPS_FIX_TYPE_3D"><description>3D</description></entry>
      <entry value="4" name="HK_GPS_FIX_TYPE_RTK_FIXED"><description>RTK 固定</description></entry>
      <entry value="5" name="HK_GPS_FIX_TYPE_RTK_FLOAT"><description>RTK 浮点</description></entry>
      <entry value="6" name="HK_GPS_FIX_TYPE_ESTIMATED"><description>估计</description></entry>
    </enum>

    <!-- ===== 起落状态 ===== -->
    <enum name="HK_LAND_STATE">
      <description>起落状态</description>
      <entry value="0" name="HK_LAND_STATE_UNKNOWN"><description>UNKNOWN</description></entry>
      <entry value="1" name="HK_LAND_STATE_ON_GROUND"><description>ON_GROUND</description></entry>
      <entry value="2" name="HK_LAND_STATE_IN_AIR"><description>IN_AIR</description></entry>
    </enum>

    <!-- ===== 任务状态 ===== -->
    <enum name="HK_TASK_STATE">
      <description>任务状态</description>
      <entry value="0" name="HK_TASK_STATE_WAIT_ATTACK"><description>等待打击</description></entry>
      <entry value="1" name="HK_TASK_STATE_FLY_TO_TARGET"><description>飞向目标</description></entry>
      <entry value="2" name="HK_TASK_STATE_ADJUST_PATH"><description>调整航路</description></entry>
      <entry value="3" name="HK_TASK_STATE_ADJUST_ANGLE"><description>调整角度</description></entry>
      <entry value="4" name="HK_TASK_STATE_CIRCLE_SEARCH"><description>盘旋搜索</description></entry>
      <entry value="5" name="HK_TASK_STATE_TURN_BACK"><description>返航</description></entry>
      <entry value="6" name="HK_TASK_STATE_WAIT_AUTHORITY"><description>等待权限</description></entry>
    </enum>

    <!-- ===== 制导模式 ===== -->
    <enum name="HK_GUIDANCE_MODE">
      <description>制导模式</description>
      <entry value="0" name="HK_GUIDANCE_MODE_TRACKING_ONLY"><description>TRACKING_ONLY</description></entry>
      <entry value="1" name="HK_GUIDANCE_MODE_PURE_PURSUIT"><description>PURE_PURSUIT</description></entry>
      <entry value="2" name="HK_GUIDANCE_MODE_PROPORTIONAL_NAVIGATION"><description>PROPORTIONAL_NAVIGATION</description></entry>
    </enum>

    <!-- ===== 飞行模式 ===== -->
    <enum name="HK_FLIGHT_MODE">
      <description>飞行模式，对应 DroneInfo.flight_mode / PX4 uORB VehicleStatus.nav_state；AP 模式由 APMavlinkAdapter 翻译为同一编号</description>
      <entry value="0" name="HK_FLIGHT_MODE_MANUAL"><description>手动模式</description></entry>
      <entry value="1" name="HK_FLIGHT_MODE_ALTCTL"><description>高度控制模式</description></entry>
      <entry value="2" name="HK_FLIGHT_MODE_POSCTL"><description>位置控制模式</description></entry>
      <entry value="3" name="HK_FLIGHT_MODE_AUTO_MISSION"><description>自动任务模式</description></entry>
      <entry value="4" name="HK_FLIGHT_MODE_AUTO_LOITER"><description>自动悬停/盘旋模式</description></entry>
      <entry value="5" name="HK_FLIGHT_MODE_AUTO_RTL"><description>自动返航模式</description></entry>
      <entry value="6" name="HK_FLIGHT_MODE_POSITION_SLOW"><description>慢速位置模式</description></entry>
      <entry value="7" name="HK_FLIGHT_MODE_FREE5"><description>保留模式 5</description></entry>
      <entry value="8" name="HK_FLIGHT_MODE_FREE4"><description>保留模式 4</description></entry>
      <entry value="9" name="HK_FLIGHT_MODE_FREE3"><description>保留模式 3</description></entry>
      <entry value="10" name="HK_FLIGHT_MODE_ACRO"><description>特技模式</description></entry>
      <entry value="11" name="HK_FLIGHT_MODE_FREE2"><description>保留模式 2</description></entry>
      <entry value="12" name="HK_FLIGHT_MODE_DESCEND"><description>自动下降模式</description></entry>
      <entry value="13" name="HK_FLIGHT_MODE_TERMINATION"><description>紧急终止模式</description></entry>
      <entry value="14" name="HK_FLIGHT_MODE_OFFBOARD"><description>外部控制模式</description></entry>
      <entry value="15" name="HK_FLIGHT_MODE_STAB"><description>自稳模式</description></entry>
      <entry value="16" name="HK_FLIGHT_MODE_FREE1"><description>保留模式 1</description></entry>
      <entry value="17" name="HK_FLIGHT_MODE_AUTO_TAKEOFF"><description>自动起飞模式</description></entry>
      <entry value="18" name="HK_FLIGHT_MODE_AUTO_LAND"><description>自动降落模式</description></entry>
      <entry value="19" name="HK_FLIGHT_MODE_AUTO_FOLLOW_TARGET"><description>自动跟踪目标模式</description></entry>
      <entry value="20" name="HK_FLIGHT_MODE_AUTO_PRECLAND"><description>自动精准降落模式</description></entry>
      <entry value="21" name="HK_FLIGHT_MODE_ORBIT"><description>环绕模式</description></entry>
      <entry value="22" name="HK_FLIGHT_MODE_AUTO_VTOL_TAKEOFF"><description>自动垂直起降转换起飞模式</description></entry>
      <entry value="23" name="HK_FLIGHT_MODE_EXTERNAL1"><description>外部自定义模式 1</description></entry>
      <entry value="24" name="HK_FLIGHT_MODE_EXTERNAL2"><description>外部自定义模式 2</description></entry>
      <entry value="25" name="HK_FLIGHT_MODE_EXTERNAL3"><description>外部自定义模式 3</description></entry>
      <entry value="26" name="HK_FLIGHT_MODE_EXTERNAL4"><description>外部自定义模式 4</description></entry>
      <entry value="27" name="HK_FLIGHT_MODE_EXTERNAL5"><description>外部自定义模式 5</description></entry>
      <entry value="28" name="HK_FLIGHT_MODE_EXTERNAL6"><description>外部自定义模式 6</description></entry>
      <entry value="29" name="HK_FLIGHT_MODE_EXTERNAL7"><description>外部自定义模式 7</description></entry>
      <entry value="30" name="HK_FLIGHT_MODE_EXTERNAL8"><description>外部自定义模式 8</description></entry>
    </enum>

    <!-- ===== VTOL 状态 ===== -->
    <enum name="HK_VTOL_STATE">
      <description>VTOL 状态</description>
      <entry value="0" name="HK_VTOL_STATE_UNDEFINED"><description>未定义</description></entry>
      <entry value="1" name="HK_VTOL_STATE_TRANSITION_TO_FW"><description>转FW中</description></entry>
      <entry value="2" name="HK_VTOL_STATE_TRANSITION_TO_MC"><description>转MC中</description></entry>
      <entry value="3" name="HK_VTOL_STATE_MC"><description>MC</description></entry>
      <entry value="4" name="HK_VTOL_STATE_FW"><description>FW</description></entry>
    </enum>

    <!-- ===== 电机状态 ===== -->
    <enum name="HK_MOTOR_STATUS_FLAG">
      <description>电机运行状态</description>
      <entry value="0" name="HK_MOTOR_STATUS_NORMAL"><description>正常</description></entry>
      <entry value="1" name="HK_MOTOR_STATUS_FAULT"><description>故障</description></entry>
    </enum>

    <!-- ===== mavlink_bridge 状态 ===== -->
    <enum name="HK_BRIDGE_STATUS">
      <description>mavlink_bridge 运行状态</description>
      <entry value="0" name="HK_BRIDGE_STATUS_INITIALIZING"><description>初始化中</description></entry>
      <entry value="1" name="HK_BRIDGE_STATUS_NORMAL"><description>正常运行</description></entry>
      <entry value="2" name="HK_BRIDGE_STATUS_WARNING"><description>告警</description></entry>
      <entry value="3" name="HK_BRIDGE_STATUS_FAULT"><description>故障</description></entry>
    </enum>

    <!-- ===== 发射箱舱盖 ===== -->
    <enum name="LID_STATUS">
      <description>发射箱舱盖状态</description>
      <entry value="0" name="LID_CLOSED"><description>已关闭</description></entry>
      <entry value="1" name="LID_OPENED"><description>已开启</description></entry>
    </enum>

    <!-- ===== 发射箱锁扣 ===== -->
    <enum name="LOCK_STATUS">
      <description>发射箱电磁锁扣状态</description>
      <entry value="0" name="LOCK_LOCKED"><description>已锁定</description></entry>
      <entry value="1" name="LOCK_RELEASED"><description>已解锁</description></entry>
    </enum>

    <!-- ===== 杀伤等级 ===== -->
    <enum name="KILL_LEVEL">
      <description>撞击杀伤等级</description>
      <entry value="0" name="KILL_DESTROYED"><description>摧毁</description></entry>
      <entry value="1" name="KILL_HEAVY_DAMAGE"><description>重创</description></entry>
      <entry value="2" name="KILL_LIGHT_DAMAGE"><description>轻伤</description></entry>
    </enum>

    <!-- ===== 跟踪算法 AI 识别状态标签 ===== -->
    <enum name="HK_TRACK_AI_STATUS_LABEL">
      <description>跟踪算法 AI 状态文本枚举，对应 recognition_status/status_label</description>
      <entry value="0" name="HK_TRACK_AI_STATUS_LABEL_INIT"><description>初始化</description></entry>
      <entry value="1" name="HK_TRACK_AI_STATUS_LABEL_DETECTING"><description>检测中</description></entry>
      <entry value="2" name="HK_TRACK_AI_STATUS_LABEL_RECOGNIZED"><description>已识别</description></entry>
      <entry value="3" name="HK_TRACK_AI_STATUS_LABEL_TRACKING"><description>跟踪中</description></entry>
    </enum>
  </enums>

  <messages>
    <!-- ===== 50000~50003：无人机 ↔ 地面站 ===== -->

    <!-- 50002: 撞击确认 -->
    <message id="50002" name="HK_IMPACT_CONFIRM">
      <description>无人机撞击目标后的确认上报，地面站据此创建拦截记录</description>
      <field type="uint8_t" name="target_id">目标 ID</field>
      <field type="int16_t" name="target_speed">目标速度（cm/s）</field>
      <field type="int16_t" name="drone_speed">无人机速度（cm/s）</field>
      <field type="int32_t" name="impact_lat">撞击点纬度（度 × 10^7）</field>
      <field type="int32_t" name="impact_lon">撞击点经度（度 × 10^7）</field>
      <field type="int32_t" name="impact_alt">撞击点海拔高度（mm）</field>
      <field type="uint8_t" name="kill_level" enum="KILL_LEVEL">0=摧毁, 1=重创, 2=轻伤</field>
    </message>

    <!-- 50003: 目标态势信息（GCS → 无人机） -->
    <message id="50003" name="HK_TARGET_SITUATION">
      <description>地面站向指定无人机下发目标态势信息（位置、速度、标准差）</description>
      <field type="uint8_t" name="target_sysid">目标无人机系统 ID（消息接收方）</field>
      <field type="int32_t" name="target_lat">目标纬度（度 × 10^7）</field>
      <field type="int32_t" name="target_lon">目标经度（度 × 10^7）</field>
      <field type="int32_t" name="target_alt">目标海拔高度（mm）</field>
      <field type="int32_t" name="speed_north">北向速度（cm/s）</field>
      <field type="int32_t" name="speed_east">东向速度（cm/s）</field>
      <field type="int32_t" name="speed_down">地向速度（cm/s）</field>
      <field type="int16_t" name="lat_std">纬度标准差（0.01°）</field>
      <field type="int16_t" name="lon_std">经度标准差（0.01°）</field>
      <field type="int16_t" name="alt_std">高度标准差（0.1 m）</field>
      <field type="int16_t" name="ned_speed_north_std">北向速度标准差（cm/s）</field>
      <field type="int16_t" name="ned_speed_east_std">东向速度标准差（cm/s）</field>
      <field type="int16_t" name="ned_speed_down_std">地向速度标准差（cm/s）</field>
      <field type="uint8_t" name="validity_mask">字段有效性掩码（bit0=位置, bit1=位置标准差, bit2=速度, bit3=速度标准差）</field>
    </message>

    <!-- ===== 50100~50116：无人机遥测 ===== -->

    <!-- 50100: 位置信息 -->
    <message id="50100" name="HK_DRONE_POSITION">
      <description>位置信息，对应 DroneInfo 第 1 组中的位置部分</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="double" name="latitude_deg">纬度（deg），范围 -90~+90</field>
      <field type="double" name="longitude_deg">经度（deg），范围 -180~+180</field>
      <field type="double" name="altitude_m">海拔高度（m，AMSL，上为正）</field>
      <field type="float" name="relative_altitude_m">相对起飞点高度（m，上为正）；home_valid=false 之前为 0（未定义）</field>
      <field type="float" name="fc_local_x_m">本地北向位置（m），AP 模式下恒为 0</field>
      <field type="float" name="fc_local_y_m">本地东向位置（m），AP 模式下恒为 0</field>
      <field type="float" name="fc_local_z_m">本地下向位置（m，下为正）</field>
    </message>

    <!-- 50101: 速度与加速度 -->
    <message id="50101" name="HK_DRONE_VELOCITY">
      <description>速度与加速度，对应 DroneInfo 第 1 组中的速度/加速度部分</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="float" name="velocity_x_mps">NED 北向速度（m/s，北为正）</field>
      <field type="float" name="velocity_y_mps">NED 东向速度（m/s，东为正）</field>
      <field type="float" name="velocity_z_mps">NED 下向速度（m/s，下降为正）</field>
      <field type="float" name="horizontal_speed_mps">水平地速（m/s）</field>
      <field type="float" name="true_airspeed_mps">真空速（m/s）</field>
      <field type="float" name="acceleration_x_mps2">NED 北向加速度（m/s²）</field>
      <field type="float" name="acceleration_y_mps2">NED 东向加速度（m/s²）</field>
      <field type="float" name="acceleration_z_mps2">NED 下向加速度（m/s²，下降加速为正）</field>
      <field type="float" name="fc_local_vx_mps">本地北向速度（m/s）</field>
      <field type="float" name="fc_local_vy_mps">本地东向速度（m/s）</field>
      <field type="float" name="fc_local_vz_mps">本地下向速度（m/s）</field>
    </message>

    <!-- 50102: 机体姿态 -->
    <message id="50102" name="HK_DRONE_ATTITUDE">
      <description>机体姿态，对应 DroneInfo 第 1 组中的姿态部分</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="float" name="roll_rad">MC 视图 body→world 滚转（rad），范围 -π~+π</field>
      <field type="float" name="pitch_rad">MC 视图 body→world 俯仰（rad），范围 -π/2~+π/2</field>
      <field type="float" name="yaw_rad">MC 视图 body→world 偏航（rad），范围 -π~+π</field>
      <field type="float" name="attitude_qx">body→world 四元数 x 分量（XYZW 顺序，Hamilton 约定，NED）</field>
      <field type="float" name="attitude_qy">body→world 四元数 y 分量</field>
      <field type="float" name="attitude_qz">body→world 四元数 z 分量</field>
      <field type="float" name="attitude_qw">body→world 四元数 w 分量</field>
      <field type="float" name="angular_velocity_x_radps">机体滚转角速度（rad/s）</field>
      <field type="float" name="angular_velocity_y_radps">机体俯仰角速度（rad/s）</field>
      <field type="float" name="angular_velocity_z_radps">机体偏航角速度（rad/s）</field>
    </message>

    <!-- 50103: 辅助姿态角 -->
    <message id="50103" name="HK_DRONE_ATTITUDE_BASE">
      <description>FW 姿态、相机姿态、气流角、速度向量角，对应 DroneInfo 第 1 组中的辅助姿态部分</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="float" name="fw_roll_rad">FW 视图滚转（rad）</field>
      <field type="float" name="fw_pitch_rad">FW 视图俯仰（rad）</field>
      <field type="float" name="fw_yaw_rad">FW 视图偏航（rad）</field>
      <field type="float" name="camera_roll_rad">相机滚转（rad）</field>
      <field type="float" name="camera_pitch_rad">相机俯仰（rad）</field>
      <field type="float" name="camera_yaw_rad">相机偏航（rad）</field>
      <field type="float" name="angle_of_attack_rad">攻角（rad）= velocity_pitch_angle_rad - pitch_rad</field>
      <field type="float" name="sideslip_angle_rad">侧滑角（rad）= velocity_yaw_angle_rad - yaw_rad</field>
      <field type="float" name="velocity_yaw_angle_rad">世界系速度向量方向偏航角（rad，NED）</field>
      <field type="float" name="velocity_pitch_angle_rad">世界系速度向量方向俯仰角（rad，NED）</field>
    </message>

    <!-- 50104: 飞控心跳 -->
    <message id="50104" name="HK_DRONE_HEARTBEAT">
      <description>飞控心跳信息，对应 DroneInfo 第 2 组</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="uint8_t" name="fc_vehicle_type">MAV_TYPE 枚举</field>
      <field type="uint8_t" name="fc_autopilot">MAV_AUTOPILOT 枚举；12=PX4，3=ArduPilot</field>
      <field type="uint8_t" name="fc_base_mode">MAV_MODE_FLAG 位掩码；当前仅 armed bit (0x80)</field>
      <field type="uint32_t" name="fc_custom_mode">自定义模式；PX4 端未填，AP 端未传</field>
      <field type="uint8_t" name="fc_system_status">MAV_STATE 枚举</field>
    </message>

    <!-- 50105: 罗盘航向 -->
    <message id="50105" name="HK_DRONE_HEADING">
      <description>罗盘航向，对应 DroneInfo 第 3 组</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="float" name="heading_deg">罗盘航向 0~360°，0=正北、顺时针</field>
    </message>

    <!-- 50106: 电池信息 -->
    <message id="50106" name="HK_DRONE_BATTERY">
      <description>电池信息，对应 DroneInfo 第 4 组</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="float" name="battery_voltage_v">电池电压（V）</field>
      <field type="float" name="battery_current_a">电池电流（A）；AP 标准规定充电为正、放电为负</field>
      <field type="float" name="battery_remaining_pct">剩余电量百分比（0~100）</field>
      <field type="int32_t" name="battery_id">电池编号，单电池为 0</field>
    </message>

    <!-- 50107: GPS 原始信息 -->
    <message id="50107" name="HK_DRONE_GPS">
      <description>GPS 原始信息，对应 DroneInfo 第 5 组</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="uint8_t" name="gps_satellites">可见卫星数</field>
      <field type="float" name="gps_hdop">水平精度因子；PX4=SensorGps.hdop，AP 模式下为 GPS_RAW_INT.eph</field>
      <field type="uint8_t" name="gps_fix_type" enum="HK_GPS_FIX_TYPE">定位类型：0=无, 1=无, 2=2D, 3=3D, 4=RTK 固定, 5=RTK 浮点, 6=估计</field>
      <field type="uint64_t" name="gps_time_utc_usec">GPS UTC 时间戳（微秒，Unix epoch）；0=无 GPS 时间</field>
    </message>

    <!-- 50108: 系统状态 -->
    <message id="50108" name="HK_DRONE_SYSTEM_STATUS">
      <description>系统状态与传感器位，对应 DroneInfo 第 6 组</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="uint32_t" name="sensors_present">传感器在位位掩码（MAV_SYS_STATUS_SENSOR_*）</field>
      <field type="uint32_t" name="sensors_health">传感器健康位掩码（MAV_SYS_STATUS_SENSOR_*）</field>
      <field type="float" name="fc_load_pct">飞控 CPU 负载百分比（0~100）</field>
    </message>

    <!-- 50109: 飞行控制 AI 状态 -->
    <message id="50109" name="HK_DRONE_AI_STATUS">
      <description>飞行控制 AI 状态，对应 DroneInfo 第 7 组</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="char[20]" name="ai_model_name">AI 模型名称</field>
      <field type="char[10]" name="ai_model_version">AI 版本号</field>
      <field type="uint8_t" name="ai_status">AI 状态：0=正常，1=故障</field>
      <field type="uint16_t" name="ai_fault_code">故障码（正常时 0）</field>
      <field type="uint16_t" name="ai_response_time_ms">AI 决策周期（ms）</field>
    </message>

    <!-- 50110: 电机状态数组 -->
    <message id="50110" name="HK_DRONE_MOTOR_STATUS">
      <description>电机状态数组，对应 DroneInfo 第 8 组；固定 12 槽</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="uint8_t" name="motor_count">实际有数据的电机数（不是 12）</field>
      <field type="int32_t[12]" name="motor_rpm">电机转速（RPM），-1 表示无数据</field>
      <field type="int8_t[12]" name="motor_temperature">电机温度（°C），-128 表示无数据</field>
      <field type="float[12]" name="motor_thrust_pct">电机推力百分比（0~100），NaN 表示无数据</field>
      <field type="uint8_t[12]" name="motor_status" enum="HK_MOTOR_STATUS_FLAG">电机状态，0=正常, 1=故障</field>
    </message>

    <!-- 50111: 飞行模式/起落/任务标志 -->
    <message id="50111" name="HK_DRONE_FLIGHT_STATUS">
      <description>飞行模式、起落状态与任务标志，对应 DroneInfo 第 9 组</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="uint8_t" name="flight_mode" enum="HK_FLIGHT_MODE">飞行模式，与 DroneInfo.flight_mode / PX4 nav_state 一致；AP 模式由 APMavlinkAdapter 翻译</field>
      <field type="uint8_t" name="is_armed">是否解锁，0=否，1=是</field>
      <field type="uint8_t" name="land_state" enum="HK_LAND_STATE">起落状态：0=UNKNOWN, 1=ON_GROUND, 2=IN_AIR</field>
      <field type="uint8_t" name="need_attack">策略 need_attack_ 标志</field>
      <field type="uint8_t" name="task_finished">任务结束标志</field>
      <field type="uint8_t" name="current_task_state" enum="HK_TASK_STATE">任务状态：0=WAIT_ATTACK, 1=FLY_TO_TARGET, 2=ADJUST_PATH, 3=ADJUST_ANGLE, 4=CIRCLE_SEARCH, 5=TURN_BACK, 6=WAIT_AUTHORITY</field>
      <field type="uint8_t" name="guidance_mode" enum="HK_GUIDANCE_MODE">制导模式：0=TRACKING_ONLY, 1=PURE_PURSUIT, 2=PROPORTIONAL_NAVIGATION</field>
    </message>

    <!-- 50112: VTOL 状态与 Home 点 -->
    <message id="50112" name="HK_DRONE_HOME_VTOL">
      <description>VTOL 状态与 Home 点，对应 DroneInfo 第 10 组</description>
      <field type="uint64_t" name="timestamp_ms">ROS 时间戳（毫秒）</field>
      <field type="uint8_t" name="vtol_state" enum="HK_VTOL_STATE">VTOL 状态：0=未定义, 1=转FW中, 2=转MC中, 3=MC, 4=FW</field>
      <field type="uint8_t" name="home_valid">Home 是否已锁定（true 后 home_* 不再变）</field>
      <field type="double" name="home_latitude_deg">Home 纬度（deg）</field>
      <field type="double" name="home_longitude_deg">Home 经度（deg）</field>
      <field type="double" name="home_altitude_m">Home 海拔（m）</field>
    </message>

    <!-- 50113: mavlink_bridge 自身心跳 -->
    <message id="50113" name="HK_MAVLINK_BRIDGE_HEART">
      <description>mavlink_bridge 自身状态心跳</description>
      <field type="uint8_t" name="bridge_status" enum="HK_BRIDGE_STATUS">mavlink_bridge 状态：0=初始化中, 1=正常运行, 2=告警, 3=故障</field>
    </message>

    <!-- 50114: GPU 状态 -->
    <message id="50114" name="HK_GPU_STATUS">
      <description>GPU 状态；原 HK_AI_STATUS.gpu_* 迁移至此</description>
      <field type="uint8_t" name="gpu_usage">GPU 使用率（%）</field>
      <field type="int8_t" name="gpu_temperature">GPU 温度（°C）</field>
    </message>

    <!-- 50115: AI 目标识别结果 -->
    <message id="50115" name="HK_DETECTION_RESULT">
      <description>AI 目标识别结果，对应 ROS2 DetectionResult 核心数字字段</description>
      <field type="uint64_t" name="timestamp_ms">时间戳（毫秒）</field>
      <field type="uint8_t" name="status">AI 状态：0=INIT, 1=DETECTING, 2=RECOGNIZED, 3=TRACKING</field>
      <field type="uint8_t" name="camera_index">相机索引：0=TELEPHOTO, 1=WIDE, 2=UNKNOWN</field>
      <field type="uint8_t" name="level">消息级别</field>
      <field type="uint8_t" name="ai_running">AI 是否运行中</field>
      <field type="uint8_t" name="has_error">是否存在错误</field>
      <field type="uint16_t" name="error_code">错误码</field>
      <field type="uint8_t" name="tracked">是否已跟踪</field>
      <field type="float" name="confidence">置信度</field>
      <field type="float" name="track_score">跟踪分数</field>
      <field type="float" name="horizontal_angle_rad">水平视线角（rad）</field>
      <field type="float" name="vertical_angle_rad">垂直视线角（rad）</field>
      <field type="float" name="distance_m">估计目标距离（m）</field>
      <field type="float[4]" name="camera_position">相机安装参数 [x,y,z,yaw]</field>
      <field type="float[4]" name="box">目标包围框 [x1,y1,x2,y2]</field>
    </message>

    <!-- 50116: AI 识别运行状态 -->
    <message id="50116" name="HK_RECOGNITION_STATUS">
      <description>AI 识别运行状态中的跟踪算法 AI 字段，对应 ROS2 RecognitionStatus 中的 track_* 字段</description>
      <field type="uint64_t" name="timestamp_ms">时间戳（毫秒）</field>
      <field type="char[20]" name="track_model_name">跟踪算法 AI 模型名称</field>
      <field type="char[10]" name="track_version">跟踪算法 AI 版本号</field>
      <field type="uint8_t" name="track_status">跟踪算法 AI 状态：0=正常, 1=故障</field>
      <field type="uint16_t" name="track_fault_code">跟踪算法 AI 故障码（正常时 0）</field>
      <field type="uint16_t" name="track_response_time">跟踪算法 AI 响应时间（ms）</field>
    </message>

    <!-- 50117: 跟踪算法 AI 关键状态日志（地面站记录） -->
    <message id="50117" name="HK_TRACK_AI_KEY_LOG">
      <description>跟踪算法 AI 关键状态日志字段，汇总 recognition_status 与 detection_result 核心字段，供地面站记录</description>
      <field type="uint64_t" name="status_timestamp_ms">recognition_status 时间戳（毫秒）</field>
      <field type="uint8_t" name="status" enum="HK_TRACK_AI_STATUS_LABEL">跟踪算法 AI 状态：0=INIT, 1=DETECTING, 2=RECOGNIZED, 3=TRACKING</field>
      <field type="uint8_t" name="ai_running">识别主循环运行状态，0=停滞/异常，1=正常</field>
      <field type="uint8_t" name="has_error">错误标志，0=正常，1=存在错误</field>
      <field type="uint16_t" name="error_code">错误码，0=正常</field>
      <field type="uint64_t" name="detection_timestamp_ms">detection_result 时间戳（毫秒）</field>
      <field type="uint8_t" name="tracked">目标跟踪标志，0=未形成稳定跟踪，1=已进入跟踪链路</field>
      <field type="float" name="horizontal_angle_rad">目标水平视线角（rad），图像中心为 0，左侧为负，右侧为正</field>
      <field type="float" name="vertical_angle_rad">目标垂直视线角（rad），图像中心为 0，下方为负，上方为正</field>
    </message>

    <!-- ===== 60000~60002：发射箱 / GNSS ↔ 地面站 ===== -->

    <!-- 60000: 发射箱状态 -->
    <message id="60000" name="HK_LAUNCHER_STATUS">
      <description>发射箱基础状态、位置和装载信息</description>
      <field type="uint8_t" name="lid_status" enum="LID_STATUS">0=已关闭, 1=已开启</field>
      <field type="uint8_t" name="lock_status" enum="LOCK_STATUS">0=已锁定, 1=已解锁</field>
      <field type="uint8_t" name="box_battery">发射箱电量（%）</field>
      <field type="uint8_t" name="ready_count">待发射无人机数量</field>
      <field type="uint8_t" name="total_count">已装载无人机总数</field>
      <field type="int32_t" name="launcer_lat">纬度（度 × 10^7）</field>
      <field type="int32_t" name="launcer_lon">经度（度 × 10^7）</field>
      <field type="int32_t" name="launcer_alt">海拔高度（mm）</field>
    </message>

    <!-- 60001: 待发射无人机列表 -->
    <message id="60001" name="HK_LAUNCHER_DETAIL">
      <description>发射箱内单架待发射无人机的详细信息，多条消息组成完整列表</description>
      <field type="uint8_t" name="drone_index">待发射无人机序号</field>
      <field type="char[20]" name="drone_name">无人机名称/编号</field>
      <field type="char[20]" name="drone_model">无人机型号名称</field>
    </message>

    <!-- 70000: 地面站 GNSS 位置 -->
    <message id="70000" name="HK_GCS_POSITION">
      <description>地面站自身 GNSS 模块位置，用于计算距离和方位角</description>
      <field type="int32_t" name="gcs_lat">纬度（度 × 10^7）</field>
      <field type="int32_t" name="gcs_lon">经度（度 × 10^7）</field>
      <field type="int32_t" name="gcs_alt">海拔高度（mm）</field>
    </message>
  </messages>
</mavlink>
